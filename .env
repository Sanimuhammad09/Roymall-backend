# ==============================================================================
# ROYMALL SCENTS BACKEND ENVIRONMENT VARIABLES
# ==============================================================================

# Application Setup
PORT=4000
FRONTEND_URL=http://localhost:3000
VITE_APP_URL=http://localhost:3000

# ==============================================================================
# SUPABASE DATABASE DETAILS
# (Copy and paste your Supabase connection strings here)
# ==============================================================================
# e.g., postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DATABASE_URL="YOUR_SUPABASE_DATABASE_URL_HERE"

# Direct connection for Prisma migrations (optional depending on setup)
DIRECT_URL="YOUR_SUPABASE_DIRECT_URL_HERE"


# ==============================================================================
# JWT Authentication Secrets
# ==============================================================================
JWT_SECRET="generate_a_strong_random_secret_here"
JWT_REFRESH_SECRET="generate_another_strong_random_secret_here"
JWT_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# ==============================================================================
# Redis Setup (If applicable)
# ==============================================================================
REDIS_HOST="localhost"
REDIS_PORT="6379"

# ==============================================================================
# Stripe Configuration
# ==============================================================================
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ==============================================================================
# Cloudinary (Image Storage)
# ==============================================================================
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# ==============================================================================
# Mail (SMTP) Configuration
# ==============================================================================
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT="2525"
SMTP_USER="your_smtp_user"
SMTP_PASS="your_smtp_pass"
MAIL_FROM="no-reply@roymallscents.com"
