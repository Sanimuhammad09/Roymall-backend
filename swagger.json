  "info": {
    "title": "Roymall Scents API",
    "description": "Premium Perfume Ecommerce Platform API",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [
    {
      "url": "https://roymall-backend-production.up.railway.app",
      "description": "Production Server"
    },
    {
      "url": "http://localhost:8080",
      "description": "Local Development Server"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "RegisterDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "jane@example.com"
          },
          "password": {
            "type": "string",
            "example": "SecurePass123!"
          },
          "firstName": {
            "type": "string",
            "example": "Jane"
          },
          "lastName": {
            "type": "string",
            "example": "Doe"
          }
        },
        "required": [
          "email",
          "password",
          "firstName",
          "lastName"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "jane@example.com"
          },
          "password": {
            "type": "string",
            "example": "SecurePass123!"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "RefreshTokenDto": {
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string"
          }
        },
        "required": [
          "refreshToken"
        ]
      },
      "ForgotPasswordDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "jane@example.com"
          }
        },
        "required": [
          "email"
        ]
      },
      "ResetPasswordDto": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string"
          },
          "newPassword": {
            "type": "string",
            "example": "NewSecurePass123!"
          }
        },
        "required": [
          "token",
          "newPassword"
        ]
      },
      "UpdateProfileDto": {
        "type": "object",
        "properties": {
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "avatar": {
            "type": "string"
          }
        }
      },
      "VariantDto": {
        "type": "object",
        "properties": {
          "sku": {
            "type": "string",
            "example": "FLV-SCR-TOP-NVY-S"
          },
          "barcode": {
            "type": "string"
          },
          "color": {
            "type": "string",
            "example": "Navy"
          },
          "colorHex": {
            "type": "string",
            "example": "#1B2A4A"
          },
          "size": {
            "type": "string",
            "example": "S"
          },
          "priceOffset": {
            "type": "number",
            "example": 0
          },
          "inventory": {
            "type": "number",
            "example": 50
          }
        },
        "required": [
          "sku",
          "color",
          "size",
          "inventory"
        ]
      },
      "ProductImageDto": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          },
          "alt": {
            "type": "string"
          },
          "order": {
            "type": "number"
          },
          "isMain": {
            "type": "boolean"
          }
        },
        "required": [
          "url"
        ]
      },
      "CreateProductDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Leon™ Three-Pocket Scrub Top"
          },
          "slug": {
            "type": "string",
            "example": "leon-three-pocket-scrub-top"
          },
          "description": {
            "type": "string",
            "example": "Our signature scrub top with three pockets..."
          },
          "fabricDetails": {
            "type": "string"
          },
          "careInstructions": {
            "type": "string"
          },
          "basePrice": {
            "type": "number",
            "example": 48
          },
          "isFeatured": {
            "type": "boolean"
          },
          "categoryId": {
            "type": "string"
          },
          "collectionId": {
            "type": "string"
          },
          "variants": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/VariantDto"
            }
          },
          "images": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ProductImageDto"
            }
          }
        },
        "required": [
          "name",
          "slug",
          "description",
          "basePrice",
          "categoryId"
        ]
      },
      "UpdateProductDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "fabricDetails": {
            "type": "string"
          },
          "careInstructions": {
            "type": "string"
          },
          "basePrice": {
            "type": "number"
          },
          "isFeatured": {
            "type": "boolean"
          },
          "isActive": {
            "type": "boolean"
          },
          "categoryId": {
            "type": "string"
          },
          "collectionId": {
            "type": "string"
          }
        }
      },
      "CreateCategoryDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Scrub Tops"
          },
          "slug": {
            "type": "string",
            "example": "scrub-tops"
          },
          "description": {
            "type": "string",
            "example": "Premium scrub tops for healthcare professionals"
          },
          "image": {
            "type": "string"
          },
          "parentId": {
            "type": "string",
            "description": "Parent category ID for subcategories"
          }
        },
        "required": [
          "name",
          "slug"
        ]
      },
      "UpdateCategoryDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "image": {
            "type": "string"
          },
          "parentId": {
            "type": "string"
          }
        }
      },
      "OrderItemDto": {
        "type": "object",
        "properties": {
          "variantId": {
            "type": "string"
          },
          "quantity": {
            "type": "number"
          },
          "price": {
            "type": "number"
          }
        },
        "required": [
          "variantId",
          "quantity",
          "price"
        ]
      },
      "CreateOrderDto": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrderItemDto"
            }
          },
          "shippingAddress": {
            "type": "object"
          },
          "subtotal": {
            "type": "number"
          },
          "tax": {
            "type": "number"
          },
          "shippingCost": {
            "type": "number"
          },
          "total": {
            "type": "number"
          },
          "couponCode": {
            "type": "string"
          },
          "discountAmount": {
            "type": "number"
          }
        },
        "required": [
          "items",
          "shippingAddress",
          "subtotal",
          "tax",
          "shippingCost",
          "total"
        ]
      },
      "AddToWishlistDto": {
        "type": "object",
        "properties": {
          "variantId": {
            "type": "string"
          }
        },
        "required": [
          "variantId"
        ]
      },
      "ValidateCouponDto": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "orderValue": {
            "type": "number"
          }
        },
        "required": [
          "code",
          "orderValue"
        ]
      },
      "CreateCouponDto": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "percentage",
              "fixed",
              "free_shipping"
            ]
          },
          "value": {
            "type": "number"
          },
          "minOrderValue": {
            "type": "number"
          },
          "maxDiscount": {
            "type": "number"
          },
          "startDate": {
            "type": "string"
          },
          "endDate": {
            "type": "string"
          },
          "usageLimit": {
            "type": "number"
          },
          "isActive": {
            "type": "boolean"
          }
        },
        "required": [
          "code",
          "type",
          "value"
        ]
      },
      "JoinWaitlistDto": {
        "type": "object",
        "properties": {
          "productId": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "userId": {
            "type": "string"
          }
        },
        "required": [
          "productId",
          "email"
        ]
      },
      "SaveFitProfileDto": {
        "type": "object",
        "properties": {
          "gender": {
            "type": "string"
          },
          "heightCm": {
            "type": "number"
          },
          "weightKg": {
            "type": "number"
          },
          "bodyShape": {
            "type": "string"
          },
          "preferredFit": {
            "type": "string"
          },
          "brandSizeRef": {
            "type": "string"
          },
          "ageRange": {
            "type": "string"
          }
        },
        "required": [
          "gender",
          "heightCm",
          "weightKg",
          "bodyShape",
          "preferredFit"
        ]
      },
      "UpdateStoreSettingsDto": {
        "type": "object",
        "properties": {
          "freeShippingThreshold": {
            "type": "number"
          },
          "flatShippingRate": {
            "type": "number"
          },
          "taxRate": {
            "type": "number"
          },
          "currency": {
            "type": "string"
          },
          "contactEmail": {
            "type": "string"
          },
          "contactPhone": {
            "type": "string"
          }
        }
      }
    }
  }
}